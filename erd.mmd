    USERS ||--o{ TICKETS : assigned_to
    SUPPORT_TEAMS ||--o{ TEAM_MEMBERS : has
    USERS ||--o{ TEAM_MEMBERS : joins
    SUPPORT_TEAMS ||--o{ CATEGORIES : routes
    CATEGORIES ||--o{ TICKETS : classifies
    PRIORITIES ||--o{ TICKETS : prioritizes
    STATUSES ||--o{ TICKETS : tracks
    SUPPORT_TEAMS ||--o{ TICKETS : owns
    TICKETS ||--o{ TICKET_ASSIGNMENT_HISTORY : records
    SUPPORT_TEAMS ||--o{ TICKET_ASSIGNMENT_HISTORY : assigned_team
    USERS ||--o{ TICKET_ASSIGNMENT_HISTORY : assigned_agent
    TICKETS ||--o{ TICKET_COMMENTS : has
    USERS ||--o{ TICKET_COMMENTS : writes
    TICKETS ||--o{ TICKET_ATTACHMENTS : has
    USERS ||--o{ TICKET_ATTACHMENTS : uploads
    USERS ||--o{ NOTIFICATIONS : receives
    TICKETS ||--o{ NOTIFICATIONS : triggers
    CATEGORIES ||--o{ KNOWLEDGE_BASE_ARTICLES : groups
    USERS ||--o{ KNOWLEDGE_BASE_ARTICLES : authors
    TICKETS ||--o{ AI_SUGGESTIONS : receives
    CATEGORIES ||--o{ AI_SUGGESTIONS : suggested_category
    PRIORITIES ||--o{ AI_SUGGESTIONS : suggested_priority
