    USERS ||--o{ ACTIVITY_LOGS : performs

    ROLES {
        uuid id PK
        varchar name
        text description
        timestamptz created_at
    }

    DEPARTMENTS {
        uuid id PK
        varchar name
        text description
        timestamptz created_at
    }

    USERS {
        uuid id PK
        uuid role_id FK
        uuid department_id FK
        varchar full_name
        varchar email
        varchar password_hash
        varchar phone
        varchar job_title
        boolean is_active
        timestamptz last_login_at
        timestamptz created_at
        timestamptz updated_at
    }

    SUPPORT_TEAMS {
        uuid id PK
        varchar name
        text description
        timestamptz created_at
    }

    TEAM_MEMBERS {
        uuid team_id PK,FK
        uuid user_id PK,FK
        varchar member_role
        timestamptz created_at
    }

    CATEGORIES {
        uuid id PK
        uuid default_team_id FK
        varchar name
        text description
        boolean is_active
        timestamptz created_at
    }

    PRIORITIES {
        uuid id PK
        varchar name
        int sort_order
        int response_target_hours
        boolean is_active
    }

    STATUSES {
        uuid id PK
        varchar name
        int sort_order
        boolean is_terminal
        boolean is_active
    }

    TICKETS {
        uuid id PK
        bigint ticket_number
        uuid requester_id FK
        uuid category_id FK
        uuid priority_id FK
        uuid status_id FK
        uuid assigned_team_id FK
        uuid assigned_to_user_id FK
        varchar title
        text description
        text cancellation_reason
        timestamptz due_at
        timestamptz resolved_at
        timestamptz closed_at
        timestamptz created_at
        timestamptz updated_at
    }

    TICKET_ASSIGNMENT_HISTORY {
        uuid id PK
        uuid ticket_id FK
        uuid assigned_team_id FK
        uuid assigned_to_user_id FK
        uuid assigned_by_user_id FK
        text note
        timestamptz created_at
    }

    TICKET_COMMENTS {
        uuid id PK
        uuid ticket_id FK
        uuid author_id FK
        text body
        boolean is_internal
        timestamptz created_at
    }

    TICKET_ATTACHMENTS {
        uuid id PK
        uuid ticket_id FK
        uuid uploaded_by_user_id FK
        varchar file_name
        text file_url
        varchar content_type
        bigint file_size_bytes
        timestamptz created_at
    }

    NOTIFICATIONS {
        uuid id PK
        uuid user_id FK
        uuid ticket_id FK
        varchar title
        text message
        boolean is_read
        timestamptz created_at
        timestamptz read_at
    }

    KNOWLEDGE_BASE_ARTICLES {
        uuid id PK
        uuid category_id FK
        uuid author_id FK
        varchar title
        text content
        boolean is_published
        timestamptz created_at
        timestamptz updated_at
    }

    AI_SUGGESTIONS {
        uuid id PK
        uuid ticket_id FK
        uuid suggested_category_id FK
        uuid suggested_priority_id FK
        text suggested_reply
        numeric confidence_score
        timestamptz created_at
    }

    ACTIVITY_LOGS {
        uuid id PK
        uuid ticket_id FK
        uuid actor_user_id FK
        varchar action
        text old_value
        text new_value
        text note
        timestamptz created_at
    }

